<?xml version="1.0" encoding="UTF-8"?>
<sdf version='1.9'>
  <model name='Lidar_drone'>
    <include merge='true'>
      <uri>model://My_droneLidar</uri>
    </include>
    <include>
      <!-- <uri>https://fuel.gazebosim.org/1.0/OpenRobotics/models/Lidar 2d v2</uri> -->
      <uri>model://lidar_2d_v2</uri>
      <pose>0 0 0.084 0 0 -0.2</pose>
    </include>
    <joint name="LidarJoint" type="fixed">
      <parent>base_link</parent>
      <child>lidar_2d_v2::link</child>
      <pose relative_to="base_link">-.1 0 .26 0 0 0</pose>
    </joint>
  </model>
</sdf>
